{
  "name": "casuya-bridge",
  "version": "0.1.0",
  "description": "Offline-first student runtime and synchronization engine for Casuya's compiled HTML lessons.",
  "type": "module",
  "main": "dist/casuya-bridge.js",
  "module": "dist/casuya-bridge.esm.js",
  "exports": {
    ".": {
      "import": "./dist/casuya-bridge.esm.js",
      "require": "./dist/casuya-bridge.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage tests/**/*.test.js",
    "build": "node scripts/build.js",
    "benchmark": "node scripts/benchmark.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "casuya",
    "education",
    "offline-first",
    "pwa",
    "sync",
    "tanzania"
  ],
  "author": "Yakobo Abeld Chusi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yakoboI/casuya-bridge.git"
  },
  "homepage": "https://casuya.co.tz",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}
